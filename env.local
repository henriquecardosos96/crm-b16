# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────────
# ID da planilha — está na URL:
# https://docs.google.com/spreadsheets/d/ESTE_TRECHO_AQUI/edit
GOOGLE_SHEET_ID=cole_o_id_da_planilha_aqui

# Dados da Service Account (Google Cloud Console → IAM → Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=labora-crm@seu-projeto.iam.gserviceaccount.com

# Chave privada — copie do credentials.json, campo "private_key"
# Mantenha as quebras de linha como \n (o código converte automaticamente)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Labora CRM

# Segredo para JWT (gere com: openssl rand -base64 32)
JWT_SECRET=gere_um_segredo_forte_aqui
